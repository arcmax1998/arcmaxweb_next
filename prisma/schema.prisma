generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Project {
  id           Int                 @id @default(autoincrement())
  slug         String              @unique(map: "Project_slug_key")
  title        String
  meta         String              @db.Text
  description  String              @db.LongText
  impact       String              @db.Text
  role         String              @default("Analyst • Architect • Coder • Tester") @db.VarChar(255)
  images       ProjectImage[]
  features     ProjectFeature[]
  technologies ProjectTechnology[]

  @@map("project")
}

model ProjectImage {
  id        Int     @id @default(autoincrement())
  imageUrl  String
  order     Int
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], map: "ProjectImage_projectId_fkey")
  @@map("projectimage")
}

model ProjectFeature {
  id        Int     @id @default(autoincrement())
  text      String
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], map: "ProjectFeature_projectId_fkey")
  @@map("projectfeature")
}

model ProjectTechnology {
  id        Int     @id @default(autoincrement())
  name      String
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], map: "ProjectTechnology_projectId_fkey")
  @@map("projecttechnology")
}

model Testimonial {
  id       Int    @id @default(autoincrement())
  initials String
  name     String
  role     String
  text     String @db.LongText
  footer   String
  theme    Json

  @@map("testimonial")
}

model Skill {
  id            Int       @id @default(autoincrement())
  category      String    @db.VarChar(100)
  categoryColor String    @db.VarChar(50)
  title         String    @db.VarChar(200)
  description   String    @db.Text
  skillsList    Json
  displayOrder Int    @default(0)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([category], map: "idx_category")
  @@index([displayOrder], map: "idx_display_order")
  @@map("skills")
}
